// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  wachtwoordHash String
  naam           String
  // Aparte voor- en achternaam, gevuld via /profiel; voor bestaande
  // accounts blijft `naam` de fallback-weergave.
  voornaam       String?
  achternaam     String?
  // Persoonlijk adres van de gebruiker (los van adressen per klus).
  // adres = legacy 'straat + huisnummer'-veld; nieuwe code schrijft
  // naar straatnaam + huisnummer + huisnummerToevoeging.
  adres          String?
  straatnaam     String?
  huisnummer     String?
  huisnummerToevoeging String?
  postcode       String?
  plaats         String?
  rol            String // "consument" | "vakman" | "admin"
  isAdmin        Boolean   @default(false)
  // ─── Multi-factor authenticatie (verplicht voor rol="admin") ───
  // totpSecret = base32 secret voor authenticator-apps. Leeg tot de
  // eerste setup is voltooid. Wordt nooit terug naar de client gestuurd
  // behalve eenmalig op de setup-pagina.
  totpSecret     String?
  // totpEnabled = true zodra de admin de eerste 6-cijferige code heeft
  // bevestigd. Zolang false moet de admin de setup-flow afmaken voor
  // andere admin-pagina's bereikbaar zijn.
  totpEnabled    Boolean   @default(false)
  // bcrypt-hashes van 8 eenmalig-bruikbare recovery codes. Hashes
  // verdwijnen één-voor-één na gebruik (verwijder element uit array).
  recoveryCodesHash String[]
  // Tijdstip van de laatste wijziging van `naam` (= schermnaam /
  // bedrijfsnaam). Wordt gebruikt om zelf-service-wijzigingen op
  // /profiel te beperken tot 1x per 30 dagen. Admin kan altijd
  // wijzigen (route /api/admin/vakmannen/[id]) zonder deze check.
  naamLaatstGewijzigd DateTime?
  vakmanType     String? // "professional" of "hobbyist", alleen voor vakmannen
  // Velden voor vakmannen (null voor consumenten)
  bedrijfsnaam   String?
  kvkNummer      String?
  kvkUittrekselUrl  String?
  kvkUittrekselNaam String?
  // werkTelefoon = zakelijk telefoonnummer (zichtbaar voor klanten via
  // klus-detail en Mijn klussen). DB-kolom blijft 'telefoon' voor
  // backward-compat met bestaande data.
  werkTelefoon   String? @map("telefoon")
  // priveTelefoon = privé-nummer dat alleen admins zien.
  priveTelefoon  String?
  werkafstand    Int? // in km
  // Werkgebied: óf via 4-cijferige postcode (regioPostcode), óf via
  // plaatsnaam (regioPlaats). Niet beide tegelijk — UI dwingt keuze af,
  // PATCH-endpoint maakt de andere leeg.
  regioPostcode  String?
  regioPlaats    String?
  // Publieke profielfoto (Vercel Blob URL onder pad 'vakman-fotos/').
  // Vakman vult zelf via /profiel; toont op /vakmannen/[id] en bij
  // reacties op klus-detail-pagina's.
  profielFotoUrl String?
  // Korte introductietekst voor publieke profielpagina.
  bio            String?
  aangemaakt     DateTime  @default(now())
  klussen        Klus[]
  reacties       Reactie[]
  resetTokens    WachtwoordResetToken[]
  leads          Lead[]
  reviews        Review[]
  werkgebiedenExtra WerkgebiedExtra[]
  showcaseFotos  ShowcaseFoto[]
  chatBerichten  ChatBericht[]

  @@index([rol])
}

model WachtwoordResetToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vervaltOp  DateTime
  gebruikt   Boolean  @default(false)
  aangemaakt DateTime @default(now())

  @@index([userId])
}

model Klus {
  id           Int       @id @default(autoincrement())
  titel        String
  beschrijving String?
  postcode     String?
  huisnummer   String?
  straatnaam   String?
  plaats       String
  categorie    String?
  voorkeurVakmanType String? // "professional", "hobbyist" of null voor 'beide'
  // Optionele klus-specs (gebruikt door de configurator op stap 2; nu
  // alleen voor categorie 'Schilder' — pilot). Per categorie zijn andere
  // velden relevant; null = niet ingevuld.
  oppervlakte  Int?      // m² (Schilder)
  binnenBuiten String?   // "binnen", "buiten", "beide" (Schilder)
  aantal       Int?      // generieke teller, bv. aantal deuren bij Schilder
  urgentie     String?   // "spoed", "deze-week", "deze-maand", "geen-haast"
  gesloten     Boolean   @default(false)
  // Moderatie: nieuwe klussen staan op 'in afwachting' totdat een admin
  // ze goedkeurt. Bestaande klussen zijn in de migration op true gezet.
  goedgekeurd  Boolean   @default(false)
  aangemaakt   DateTime  @default(now())
  reacties     Reactie[]
  leads        Lead[]
  // Eigenaar van de klus (consument). Nullable voor bestaande klussen
  // die zonder account zijn aangemaakt.
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id])
  // Auto-bijgewerkt door Prisma bij elke wijziging — gebruikt door de
  // admin live-monitor om "recent gesloten" klussen op te pikken.
  bijgewerktOp DateTime  @default(now()) @updatedAt

  @@index([userId])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Lead {
  id        Int      @id @default(autoincrement())
  klusId    Int
  klus      Klus     @relation(fields: [klusId], references: [id], onDelete: Cascade)
  vakmanId  Int
  vakman    User     @relation(fields: [vakmanId], references: [id], onDelete: Cascade)
  bedrag    Int // in centen, 1000 = 10 euro
  gekochtOp DateTime @default(now())
  review    Review?
  chatBerichten ChatBericht[]

  @@unique([klusId, vakmanId])
  @@index([klusId])
  @@index([vakmanId])
}

// Review die een consument schrijft voor een vakman, gekoppeld aan
// een specifieke lead. Maximaal 1 review per lead (uniek leadId).
// Mag pas na 10 dagen na lead-aankoop (gekochtOp) — afgedwongen in API.
model Review {
  id          Int      @id @default(autoincrement())
  leadId      Int      @unique
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  consumentId Int
  consument   User     @relation(fields: [consumentId], references: [id])
  score       Int // 1 t/m 5
  tekst       String?
  fotoUrls    String[] // max 5, afgedwongen in API
  aangemaakt  DateTime @default(now())

  @@index([consumentId])
}

model Reactie {
  id         Int      @id @default(autoincrement())
  klusId     Int
  klus       Klus     @relation(fields: [klusId], references: [id], onDelete: Cascade)
  naam       String
  bericht    String
  aangemaakt DateTime @default(now())
  // Vakman die reageerde. Nullable zodat bestaande anonieme reacties
  // niet kapot gaan.
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])

  @@index([klusId])
  @@index([userId])
}

// Extra werkgebieden voor Vakmannen (alleen Pro). Het primaire werk-
// gebied blijft op User (regioPostcode/regioPlaats/werkafstand) voor
// backward-compat — alle bestaande code die daar leest blijft werken.
// Buurtklussers krijgen geen extra werkgebieden in de admin-UI.
model WerkgebiedExtra {
  id          Int    @id @default(autoincrement())
  userId      Int
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // "postcode" of "plaats"
  waarde      String
  werkafstand Int

  @@index([userId])
}

// Showcase-foto's: portfolio-galerij voor vakmannen op hun publieke
// profielpagina. Vakman uploadt JPG/PNG/WEBP (client-side geresized
// vóór upload zodat de lambda klein blijft). Admin kan modereren.
// Max 20 foto's per vakman afgedwongen in API.
model ShowcaseFoto {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String   // Vercel Blob, pad 'showcase/{userId}/...' — Voor-foto als urlNa gevuld is
  urlNa        String?  // Vercel Blob — als gevuld: dit is een Voor/Na-paar (url = Voor, urlNa = Na)
  beschrijving String?  @db.Text // optioneel bijschrift
  volgorde     Int      @default(0) // sortering — laagste eerst
  aangemaakt   DateTime @default(now())

  @@index([userId, volgorde])
}

model Trefwoord {
  id           Int       @id @default(autoincrement())
  categorieId  Int
  categorieRef Categorie @relation(fields: [categorieId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  woord        String
  type         String    @default("zoekterm") // "zoekterm" of "merk"

  @@unique([categorieId, woord])
  @@index([type])
}

model Categorie {
  id          Int         @id @default(autoincrement())
  naam        String      @unique
  volgorde    Int         @default(0)
  trefwoorden Trefwoord[]
}

// ─────────────────────────────────────────────────────────────────
// SOVEREIGN GUARDIAN — Foundation tabellen voor admin-monitoring
// ─────────────────────────────────────────────────────────────────

// ActivityEvent = single source of truth voor alle business-events op
// het platform. Wordt gevuld door API-routes via lib/events.js.
// Gebruikt door: live-feed, User Journey Timeline, KPI-aggregaties,
// anomalie-detectie. Append-only — nooit muteren of verwijderen.
model ActivityEvent {
  id          BigInt   @id @default(autoincrement())
  type        String   // 'klus.aangemaakt' | 'lead.gekocht' | 'review.geplaatst' | 'gebruiker.geregistreerd' | etc.
  tijdstip    DateTime @default(now())
  actorId     Int? // wie deed het (userId)
  actorRol    String? // 'consument' | 'vakman' | 'admin' | null voor system
  targetType  String? // 'klus' | 'lead' | 'review' | 'user' | etc.
  targetId    Int?
  payload     Json // event-specifieke data (zonder PII waar mogelijk)
  ipHash      String? // SHA256(ip) voor dedup zonder PII

  @@index([tijdstip])
  @@index([type, tijdstip])
  @@index([actorId, tijdstip])
  @@index([targetType, targetId])
}

// AuditLog = onveranderbaar logboek van admin-acties. Hash-chain
// zorgt dat manipulatie detecteerbaar is. Database-niveau borging
// via Postgres-rules tegen UPDATE/DELETE wordt later toegevoegd.
model AuditLog {
  id              BigInt    @id @default(autoincrement())
  tijdstip        DateTime  @default(now())
  adminId         Int
  adminNaam       String // gedenormaliseerd voor leesbaarheid bij user-deletie
  actie           String // 'vakman.frozen' | 'klus.verwijderd' | 'data.bekeken' | etc.
  actieCategorie  String // 'compliance' | 'pricing' | 'ranking' | 'support' | 'data'
  targetType      String
  targetId        Int?
  payload         Json // before/after state of context
  reden           String   @db.Text // verplicht ≥ 30 tekens
  ipAdres         String?
  userAgent       String?  @db.Text
  goedgekeurdDoor Int? // 4-ogen-principe — null als niet vereist
  goedgekeurdOp   DateTime?
  vorigHash       Bytes? // SHA-256 van vorige rij
  rijHash         Bytes // SHA-256(deze rij + vorigHash)

  @@index([tijdstip])
  @@index([adminId, tijdstip])
  @@index([targetType, targetId])
  @@index([actieCategorie, tijdstip])
}

// Chat tussen vakman en consument na lead-aankoop. Eén lead = één
// gesprek-thread tussen die specifieke vakman en de consument-eigenaar
// van de klus. Vakman moet altijd het eerste bericht sturen
// (afgedwongen in API). 'gelezen' wordt true zodra de wederpartij de
// chat opent.
model ChatBericht {
  id          Int      @id @default(autoincrement())
  leadId      Int
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vanUserId   Int
  vanUser     User     @relation(fields: [vanUserId], references: [id], onDelete: Cascade)
  tekst       String   @db.Text
  gelezen     Boolean  @default(false)
  aangemaakt  DateTime @default(now())

  @@index([leadId, aangemaakt])
  @@index([vanUserId])
}
