// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  wachtwoordHash String
  naam           String
  rol            String // "consument" of "vakman"
  // Velden voor vakmannen (null voor consumenten)
  bedrijfsnaam   String?
  kvkNummer      String?
  telefoon       String?
  werkafstand    Int? // in km
  regioPostcode  String? // postcode-4 als centrum van werkgebied
  aangemaakt     DateTime  @default(now())
  klussen        Klus[]
  reacties       Reactie[]
  resetTokens    WachtwoordResetToken[]

  @@index([rol])
}

model WachtwoordResetToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vervaltOp  DateTime
  gebruikt   Boolean  @default(false)
  aangemaakt DateTime @default(now())

  @@index([userId])
}

model Klus {
  id           Int       @id @default(autoincrement())
  titel        String
  beschrijving String?
  postcode     String?
  huisnummer   String?
  straatnaam   String?
  plaats       String
  categorie    String?
  aangemaakt   DateTime  @default(now())
  reacties     Reactie[]
  // Eigenaar van de klus (consument). Nullable voor bestaande klussen
  // die zonder account zijn aangemaakt.
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Reactie {
  id         Int      @id @default(autoincrement())
  klusId     Int
  klus       Klus     @relation(fields: [klusId], references: [id], onDelete: Cascade)
  naam       String
  bericht    String
  aangemaakt DateTime @default(now())
  // Vakman die reageerde. Nullable zodat bestaande anonieme reacties
  // niet kapot gaan.
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])

  @@index([klusId])
  @@index([userId])
}

model Trefwoord {
  id        Int    @id @default(autoincrement())
  categorie String
  woord     String

  @@unique([categorie, woord])
}
