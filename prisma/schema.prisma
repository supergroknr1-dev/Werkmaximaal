// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Klus {
  id           Int       @id @default(autoincrement())
  titel        String
  beschrijving String?
  postcode     String?
  plaats       String
  categorie    String?
  aangemaakt   DateTime  @default(now())
  reacties     Reactie[]
}

model Reactie {
  id         Int      @id @default(autoincrement())
  klusId     Int
  klus       Klus     @relation(fields: [klusId], references: [id], onDelete: Cascade)
  naam       String
  bericht    String
  aangemaakt DateTime @default(now())

  @@index([klusId])
}

model Trefwoord {
  id        Int    @id @default(autoincrement())
  categorie String
  woord     String

  @@unique([categorie, woord])
}
